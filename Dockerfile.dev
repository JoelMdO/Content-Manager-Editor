# Development Dockerfile with pnpm
FROM node:22-alpine

# Install pnpm globally
RUN corepack enable && corepack prepare pnpm@latest --activate

# Install libc6-compat for Next.js
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install

# Don't copy source code - it will be mounted as a volume

# Enable Node.js inspector for debugging
ENV NODE_OPTIONS='--inspect=0.0.0.0:9229'

# Enable polling for file change detection in Docker
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true

EXPOSE 8000 9229

CMD ["pnpm", "dev", "--port", "8000"]
